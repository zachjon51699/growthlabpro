# Copy this file to `.env.local` in the project root and fill in real values.
# Restart `npm run dev` after any change.

# GoHighLevel — contractor opt-in modal form
VITE_GHL_API_KEY=
VITE_GHL_LOCATION_ID=

# Optional (default: https://services.leadconnectorhq.com)
# VITE_GHL_API_BASE=https://services.leadconnectorhq.com

# Optional booking calendar on /contractor-optin (defaults to GrowthLabPro calendar)
# VITE_BOOKING_WIDGET_URL=https://api.leadconnectorhq.com/widget/booking/IRUVPTnnjfSdhvBguaB7

# Stripe (main site checkout — if used)
# VITE_STRIPE_PUBLISHABLE_KEY=

# Vite dev: set to 1 if file saves do not hot-reload (iCloud/OneDrive folders)
# VITE_DEV_POLL=1
