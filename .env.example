# Copy this file to `.env` / `.env.local` for local development.
# Restart the dev server after any change.

# GoHighLevel — used ONLY by Netlify functions / local Vite function middleware (server-side).
# Do NOT prefix these with VITE_ (that would expose them in the browser).
# On production, set these in the Netlify UI instead.
# GHL_PRIVATE_INTEGRATION_TOKEN=
# GHL_LOCATION_ID=

# Optional booking calendar on /contractor-optin
# VITE_BOOKING_WIDGET_URL=https://api.leadconnectorhq.com/widget/booking/IRUVPTnnjfSdhvBguaB7

# Stripe (main site checkout — if used)
# VITE_STRIPE_PUBLISHABLE_KEY=

# Vite dev: set to 1 if file saves do not hot-reload (iCloud/OneDrive folders)
# VITE_DEV_POLL=1
